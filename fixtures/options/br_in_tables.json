[
  {
    "id": "options_br_in_tables_true",
    "description": "BR elements in table cells render as line breaks",
    "input": {
      "html": "<table><tr><th>Header</th></tr><tr><td>Line 1<br>Line 2</td></tr></table>",
      "options": {
        "brInTables": true
      }
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": ["Header", "Line 1", "Line 2"]
      }
    ]
  },
  {
    "id": "options_br_in_tables_false",
    "description": "BR elements in table cells are stripped when disabled",
    "input": {
      "html": "<table><tr><th>Col</th></tr><tr><td>A<br>B</td></tr></table>",
      "options": {
        "brInTables": false
      }
    },
    "assertions": [
      {
        "type": "contains_all",
        "field": "content",
        "values": ["Col"]
      }
    ]
  }
]
