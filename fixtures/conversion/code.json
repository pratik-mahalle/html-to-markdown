[
  {
    "id": "inline_code",
    "description": "Inline code",
    "html": "<p>Use <code>console.log()</code> to debug</p>",
    "assertions": { "content_contains_all": ["`console.log()`"] }
  },
  {
    "id": "code_block",
    "description": "Code block with language preserves content",
    "html": "<pre><code class=\"language-python\">print('hello')</code></pre>",
    "assertions": { "content_contains_all": ["print('hello')"], "content_not_empty": true }
  },
  {
    "id": "code_block_no_language",
    "description": "Code block without a language class preserves content",
    "html": "<pre><code>plain code here</code></pre>",
    "assertions": { "content_contains_all": ["plain code here"], "content_not_empty": true }
  },
  {
    "id": "code_with_backticks_in_content",
    "description": "Inline code containing backtick characters is properly escaped",
    "html": "<p>Use <code>`backtick` here</code> carefully.</p>",
    "assertions": {
      "content_contains_all": ["backtick"],
      "content_not_empty": true
    }
  },
  {
    "id": "code_inline_in_paragraph",
    "description": "Inline code element nested inside a paragraph",
    "html": "<p>Call the <code>initialize()</code> method first.</p>",
    "assertions": { "content_contains_all": ["`initialize()`"] }
  }
]
