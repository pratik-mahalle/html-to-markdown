{
  "name": "kreuzberg-dev/html-to-markdown-test-app",
  "description": "Test app for html-to-markdown PHP package - validates published Packagist package",
  "require": {
    "php": ">=8.4",
    "kreuzberg-dev/html-to-markdown": ">=2.28.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11"
  },
  "config": {
    "platform": {
      "php": "8.4.0"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": ""
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpstan analyse SmokeTest.php ComprehensiveTest.php"
  }
}
