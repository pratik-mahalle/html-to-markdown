[
  {
    "id": "paragraph_simple",
    "description": "Simple paragraph converts to plain text",
    "html": "<p>Hello World</p>",
    "assertions": { "content_equals": "Hello World" }
  },
  {
    "id": "paragraph_multiple",
    "description": "Multiple paragraphs are separated by a blank line",
    "html": "<p>First paragraph.</p><p>Second paragraph.</p>",
    "assertions": { "content_contains_all": ["First paragraph.", "Second paragraph."] }
  },
  {
    "id": "paragraph_with_inline_formatting",
    "description": "Paragraph with bold, italic, and a link",
    "html": "<p>This has <strong>bold</strong>, <em>italic</em>, and a <a href=\"https://example.com\">link</a>.</p>",
    "assertions": {
      "content_contains_all": ["**bold**", "*italic*", "[link](https://example.com)"]
    }
  },
  {
    "id": "paragraph_with_line_breaks",
    "description": "Paragraph with br tags produces line breaks in output",
    "html": "<p>Line one.<br>Line two.<br>Line three.</p>",
    "assertions": {
      "content_contains_all": ["Line one.", "Line two.", "Line three."],
      "content_not_empty": true
    }
  },
  {
    "id": "paragraph_nested_divs",
    "description": "Text nested inside divs is extracted correctly",
    "html": "<div><div><p>Nested text</p></div></div>",
    "assertions": { "content_contains_all": ["Nested text"] }
  }
]
