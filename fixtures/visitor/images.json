[
  {
    "id": "visitor_skip_images",
    "description": "Visitor skips all images from output",
    "input": {
      "html": "<p>Before image</p><img src=\"photo.jpg\" alt=\"A photo\"><p>After image</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_image": {
          "action": "skip"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "Before image"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "After image"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "photo.jpg"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "A photo"
      }
    ]
  },
  {
    "id": "visitor_custom_image",
    "description": "Visitor replaces image with custom output using template",
    "input": {
      "html": "<img src=\"banner.png\" alt=\"Banner\">"
    },
    "visitor": {
      "callbacks": {
        "visit_image": {
          "action": "custom_template",
          "template": "[Image: {alt}]"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "[Image: Banner]"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "banner.png"
      }
    ]
  }
]
