  result.content |> list.is_empty |> should.equal(False)
  result.content |> string.contains("Expression") |> should.equal(True)
  result.content |> string.contains("Result") |> should.equal(True)
  result.content |> string.contains("true") |> should.equal(True)
}

// Table with column alignment attributes
pub fn table_with_alignment_test() {
  let result = html_to_markdown.convert("<table><thead><tr><th align=\"left\">Left</th><th align=\"center\">Center</th><th align=\"right\">Right</th></tr></thead><tbody><tr><td>L</td><td>C</td><td>R</td></tr></tbody></table>")
