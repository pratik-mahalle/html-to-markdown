[
  {
    "id": "options_list_indent_tabs",
    "description": "Tab indentation type for nested list items",
    "html": "<ul><li>Parent<ul><li>Child</li></ul></li></ul>",
    "options": { "listIndentType": "tabs" },
    "assertions": {
      "content_contains_all": ["Parent", "Child"],
      "content_not_empty": true
    }
  },
  {
    "id": "options_list_custom_bullets",
    "description": "Custom bullet character for unordered lists",
    "html": "<ul><li>Item A</li><li>Item B</li></ul>",
    "options": { "bullets": "*" },
    "assertions": {
      "content_contains_all": ["* Item A", "* Item B"]
    }
  }
]
