[
  {
    "id": "visitor_custom_heading",
    "description": "Visitor replaces heading with custom format",
    "input": {
      "html": "<h2>Section Title</h2><p>Content below heading.</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_heading": {
          "action": "custom_template",
          "template": "--- {text} ---"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "--- Section Title ---"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "## Section Title"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "Content below heading."
      }
    ]
  },
  {
    "id": "visitor_skip_all_headings",
    "description": "Visitor skips all headings from document",
    "input": {
      "html": "<h1>Title</h1><p>Body text remains.</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_heading": {
          "action": "skip"
        }
      }
    },
    "assertions": [
      {
        "type": "not_contains",
        "field": "content",
        "value": "Title"
      },
      {
        "type": "contains",
        "field": "content",
        "value": "Body text remains."
      }
    ]
  }
]
