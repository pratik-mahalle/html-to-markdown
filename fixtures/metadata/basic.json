[
  {
    "id": "metadata_title_tag",
    "description": "Extract title from <title> tag",
    "html": "<html><head><title>My Page</title></head><body><p>Content</p></body></html>",
    "options": { "extract_metadata": true },
    "assertions": {
      "content_not_empty": true,
      "metadata_title": "My Page"
    }
  },
  {
    "id": "metadata_description_meta",
    "description": "Extract description from <meta name='description'> tag",
    "html": "<html><head><title>Page</title><meta name=\"description\" content=\"This is the page description.\"></head><body><p>Content</p></body></html>",
    "options": { "extract_metadata": true },
    "assertions": {
      "content_not_empty": true,
      "metadata_description": "This is the page description."
    }
  },
  {
    "id": "metadata_author_meta",
    "description": "Extract author from <meta name='author'> tag",
    "html": "<html><head><title>Page</title><meta name=\"author\" content=\"Jane Doe\"></head><body><p>Content</p></body></html>",
    "options": { "extract_metadata": true },
    "assertions": {
      "content_not_empty": true,
      "metadata_author": "Jane Doe"
    }
  },
  {
    "id": "metadata_keywords_meta",
    "description": "Extract keywords from <meta name='keywords'> tag",
    "html": "<html><head><title>Page</title><meta name=\"keywords\" content=\"rust, markdown, html, converter\"></head><body><p>Content</p></body></html>",
    "options": { "extract_metadata": true },
    "assertions": {
      "content_not_empty": true,
      "metadata_keywords": "rust, markdown, html, converter"
    }
  },
  {
    "id": "metadata_canonical_url",
    "description": "Extract canonical URL from <link rel='canonical'> tag",
    "html": "<html><head><title>Page</title><link rel=\"canonical\" href=\"https://example.com/canonical-page\"></head><body><p>Content</p></body></html>",
    "options": { "extract_metadata": true },
    "assertions": {
      "content_not_empty": true,
      "metadata_canonical_url": "https://example.com/canonical-page"
    }
  }
]
