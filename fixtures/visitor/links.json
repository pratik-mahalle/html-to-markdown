[
  {
    "id": "visitor_custom_link_format",
    "description": "Visitor reformats links using template interpolation",
    "input": {
      "html": "<p>Visit <a href=\"https://example.com\">Example</a> for more info.</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_link": {
          "action": "custom_template",
          "template": "{text} ({href})"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "Example (https://example.com)"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "[Example]"
      }
    ]
  },
  {
    "id": "visitor_skip_links",
    "description": "Visitor skips all links entirely",
    "input": {
      "html": "<p>Before <a href=\"https://example.com\">link text</a> after</p>"
    },
    "visitor": {
      "callbacks": {
        "visit_link": {
          "action": "skip"
        }
      }
    },
    "assertions": [
      {
        "type": "not_contains",
        "field": "content",
        "value": "link text"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "example.com"
      }
    ]
  },
  {
    "id": "visitor_custom_link_static",
    "description": "Visitor replaces link with static custom output",
    "input": {
      "html": "<a href=\"https://example.com\">Click here</a>"
    },
    "visitor": {
      "callbacks": {
        "visit_link": {
          "action": "custom",
          "output": "[REDACTED LINK]"
        }
      }
    },
    "assertions": [
      {
        "type": "contains",
        "field": "content",
        "value": "[REDACTED LINK]"
      },
      {
        "type": "not_contains",
        "field": "content",
        "value": "example.com"
      }
    ]
  }
]
